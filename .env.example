# TagStudio Configuration

# Directory containing your music files (mounted into Docker container)
TAGSTUDIO_DATA_DIR=/data

# Web server settings
TAGSTUDIO_PORT=8080
TAGSTUDIO_HOST=0.0.0.0

# Authentication (set to true to require login)
TAGSTUDIO_AUTH_ENABLED=false
TAGSTUDIO_USERNAME=admin
TAGSTUDIO_PASSWORD=changeme

# Session secret (auto-generated if not set)
# TAGSTUDIO_SESSION_SECRET=your-secret-here

# Discogs API token (optional, for Discogs lookups)
# DISCOGS_API_TOKEN=your-token-here

# Frontend static files location (set automatically in Docker)
# TAGSTUDIO_STATIC_DIR=/srv/static
